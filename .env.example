# Cursor Instant Noodle - API keys template
# This file is copied to ~/.cursor-noodle/.env on first run.
# Edit it there (or run `cursor-noodle setup` / `cursor-noodle cheapmf`).

# ============================================================
# PROVIDER API KEYS
# ============================================================

# Opencode Zen (https://opencode.ai/zen/v1)
# Get yours at: https://opencode.ai/zen
# 50+ models including gpt-5.5, claude-opus-4-8, gemini-3.5-flash, big-pickle
# MULTI-ACCOUNT: paste multiple keys separated by commas. The proxy will
# round-robin between them so rate limits and quotas are spread across accounts.
# OPENCODE_ZEN_API_KEY=sk-key-1,sk-key-2,sk-key-3

# Opencode Go (https://opencode.ai/zen/go/v1)
# Hosts MiniMax, GLM, Kimi, Qwen, DeepSeek, etc.
# Leave commented to fall back to OPENCODE_ZEN_API_KEY.
# OPENCODE_GO_API_KEY=sk-your-key-here
# OPENCODE_GO_API_KEY=sk-key-1,sk-key-2  ← also supports multi-account

# z.ai / GLM direct API (https://api.z.ai/api/coding/paas/v4)
# If not set, falls back to zai-coding-plan from ~/.local/share/opencode/auth.json
# ZAI_API_KEY=your-zai-key
# ZAI_API_KEY=key-1,key-2  ← comma-separated for round-robin
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# Antigravity OAuth (recommended: run `cursor-noodle setup` and sign in)
# Multiple accounts are stored comma-separated and used as sticky failover.
# ANTIGRAVITY_REFRESH_TOKEN=refresh-token-1,refresh-token-2
# ANTIGRAVITY_EMAIL=you@gmail.com,other@gmail.com
# ANTIGRAVITY_PROJECT_ID=rising-fact-p41fc,rising-fact-p41fc
# ANTIGRAVITY_CLIENT_ID=filled-by-setup
# ANTIGRAVITY_CLIENT_SECRET=filled-by-setup
# ANTIGRAVITY_ENDPOINT=https://daily-cloudcode-pa.sandbox.googleapis.com/v1internal:streamGenerateContent?alt=sse

# Codex / ChatGPT OAuth (recommended: run `cursor-noodle setup` and sign in)
# Multiple accounts are stored comma-separated and used as sticky failover.
# CODEX_CLIENT_ID=filled-by-setup
# CODEX_REFRESH_TOKEN=refresh-token-1,refresh-token-2
# CODEX_ACCESS_TOKEN=access-token-1,access-token-2
# CODEX_ID_TOKEN=id-token-1,id-token-2
# CODEX_ACCOUNT_ID=account-id-1,account-id-2
# CODEX_EMAIL=you@example.com,other@example.com

# ============================================================
# LOCAL PROVIDERS
# ============================================================

# LMStudio (default: http://localhost:1234/v1)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_API_KEY=lmstudio

# llama.cpp server (default: http://localhost:8080/v1)
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# LLAMACPP_API_KEY=llamacpp

# Unsloth Studio (default: http://localhost:11434/v1)
# UNSLOTH_BASE_URL=http://localhost:11434/v1
# UNSLOTH_API_KEY=unsloth

# ============================================================
# SERVER
# ============================================================

PORT=6767

# Override the data directory (default: ~/.cursor-noodle)
# CURSOR_NOODLE_DATA_DIR=~/.cursor-noodle
